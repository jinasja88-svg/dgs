# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
.nyc_output/

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# Capacitor native projects
/android/
/ios/

# typescript
*.tsbuildinfo
next-env.d.ts

# Plans (Claude Code)
.plans/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Streamlit
streamlit/__pycache__/
streamlit/*.pyc
streamlit/.streamlit/secrets.toml

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
*.egg-info/
